{
    "version": 2,
    "buildCommand": "composer install --no-dev",
    "functions": {
        "api/index.php": {
        "runtime": "now-php@0.5.4"
        }
    },
    "routes": [
        {
        "src": "/(.*)",
        "dest": "api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false"
    }
}
