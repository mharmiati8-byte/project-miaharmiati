{
  "version": 2,
  "buildCommand": "composer install --no-dev",
  "functions": {
    "api/index.php": {
      "runtime": "php:8.2",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false"
  }
}
